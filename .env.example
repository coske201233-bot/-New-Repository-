# Supabase App Configuration
# Rename this file to .env.local and fill in the values from your Supabase Dashboard

# [MANDATORY] Supabase URL (e.g., https://xyz.supabase.co)
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here

# [MANDATORY] Supabase Anon Key
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
